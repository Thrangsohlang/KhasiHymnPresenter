<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel>
        <Label Margin="16,16,16,0" BorderThickness="2" BorderBrush="Black">
            <StackPanel Orientation="Horizontal">
                <Image Width="60" Height="32" Source="https://pics.freeicons.io/uploads/icons/png/3017359321711469415-512.png" />
                <AccessText Margin="2,0,0,0" FontSize="32" Text="Message" FontWeight="Bold" />
            </StackPanel>
        </Label>
        <TextBox 
            Margin="16" 
            FontSize="32" 
            TextChanged="TextBox_TextChanged" 
            Text="Dear Sir or Madame, I would like to let you know that I am"
            AcceptsReturn="True"
            TextWrapping="Wrap">
            
        </TextBox>
    </StackPanel>
</Window>
