<Application x:Class="NativeHymnsApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style TargetType="Window">
            <Setter Property="Background" Value="#0B1015" />
            <Setter Property="Foreground" Value="#F4F1E8" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="#0F161B" />
            <Setter Property="Foreground" Value="#F4F1E8" />
            <Setter Property="Padding" Value="10,4" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#F4F1E8" />
            <Setter Property="Background" Value="#0F161B" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="2,0" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="#243848" />
            <Setter Property="Foreground" Value="#F4F1E8" />
            <Setter Property="BorderBrush" Value="#34586E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2F4E60" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#4A7A92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1B2E39" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="#13202A" />
            <Setter Property="Foreground" Value="#F4F1E8" />
            <Setter Property="BorderBrush" Value="#34586E" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Background" Value="#13202A" />
            <Setter Property="Foreground" Value="#F4F1E8" />
            <Setter Property="BorderBrush" Value="#34586E" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Foreground" Value="#F4F1E8" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#101920" />
            <Setter Property="Foreground" Value="#F4F1E8" />
            <Setter Property="BorderBrush" Value="#2B4658" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
    </Application.Resources>
</Application>
