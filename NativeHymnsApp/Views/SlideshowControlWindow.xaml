<Window x:Class="NativeHymnsApp.Views.SlideshowControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:NativeHymnsApp.Models"
        mc:Ignorable="d"
        Title="Slideshow Control"
        Width="1380"
        Height="900"
        MinWidth="1160"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        KeyDown="SlideshowControlWindow_OnKeyDown">
    <Window.InputBindings>
        <KeyBinding Key="PageDown" Command="{Binding NextSlideCommand}" />
        <KeyBinding Key="PageUp" Command="{Binding PreviousSlideCommand}" />
        <KeyBinding Key="Right" Command="{Binding NextSlideCommand}" />
        <KeyBinding Key="Left" Command="{Binding PreviousSlideCommand}" />
        <KeyBinding Key="B" Command="{Binding BlackScreenCommand}" />
        <KeyBinding Key="W" Command="{Binding BlankScreenCommand}" />
        <KeyBinding Key="Escape" Command="{Binding ClearOverlayCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="ShellCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppCanvasBrush}" Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="260" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource ShellCardStyle}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Live Slideshow Control" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource AppMutedInkBrush}"
                               Text="{Binding CurrentPresentationSummary}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,10,0,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="{Binding LiveDeckTitle}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource AppMutedInkBrush}"
                               Text="{Binding LiveDeckSubtitle}"
                               TextWrapping="Wrap" />

                    <WrapPanel Margin="0,16,0,0">
                        <Button Command="{Binding PreviousSlideCommand}" Content="Previous" />
                        <Button Command="{Binding NextSlideCommand}" Content="Next" />
                        <Button Command="{Binding BlankScreenCommand}" Content="Blank" />
                        <Button Command="{Binding BlackScreenCommand}" Content="Black" />
                        <Button Command="{Binding ClearOverlayCommand}" Content="Clear Overlay" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource ShellCardStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Active Slides" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{StaticResource AppMutedInkBrush}"
                                   Text="Select any slide in the current deck to jump directly to it."
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding ActivePresentationSlides}"
                             SelectedItem="{Binding SelectedActiveSlide}"
                             BorderThickness="0"
                             Background="Transparent"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SlideSection}">
                                <Border x:Name="SlideCard"
                                        Margin="0,0,0,8"
                                        Padding="12"
                                        CornerRadius="12"
                                        Background="{StaticResource AppSurfaceAltBrush}"
                                        BorderBrush="{StaticResource AppBorderBrush}"
                                        BorderThickness="1">
                                    <DockPanel LastChildFill="True">
                                        <Button DockPanel.Dock="Right"
                                                Style="{StaticResource IconButtonStyle}"
                                                ToolTip="Go to slide"
                                                Command="{Binding DataContext.JumpToSlideCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Content="&#xE768;" />
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="{Binding Heading}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Order, StringFormat=Slide {0}}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{StaticResource AppMutedInkBrush}"
                                                       Text="{Binding Text}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="SlideCard" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                                        <Setter TargetName="SlideCard" Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Row="2"
                          Height="12"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="Transparent"
                          ShowsPreview="True" />

            <Border Grid.Row="3" Style="{StaticResource ShellCardStyle}" Margin="0,0,0,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Service Plan Load" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{StaticResource AppMutedInkBrush}"
                                   Text="Load the next queued item directly from the live control surface."
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding ServicePlanItems}"
                             SelectedItem="{Binding SelectedServicePlanEntry}"
                             BorderThickness="0"
                             Background="Transparent"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ServicePlanEntry}">
                                <Border x:Name="PlanCard"
                                        Margin="0,0,0,8"
                                        Padding="12"
                                        CornerRadius="12"
                                        Background="{StaticResource AppSurfaceAltBrush}"
                                        BorderBrush="{StaticResource AppBorderBrush}"
                                        BorderThickness="1">
                                    <DockPanel LastChildFill="True">
                                        <Button DockPanel.Dock="Right"
                                                Style="{StaticResource IconButtonStyle}"
                                                ToolTip="Load to projector"
                                                Command="{Binding DataContext.PresentServicePlanItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Content="&#xE768;" />
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding DisplayTitle}" TextWrapping="Wrap" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{StaticResource AppMutedInkBrush}"
                                                       Text="{Binding SlideCountLabel}" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="PlanCard" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                                        <Setter TargetName="PlanCard" Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <GridSplitter Grid.Column="1"
                      Width="12"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      ShowsPreview="True" />

        <Border Grid.Column="2" Style="{StaticResource ShellCardStyle}" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Projector Preview" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource AppMutedInkBrush}"
                               Text="This panel mirrors the active presenter content. On dual-display setups the fullscreen projector window stays in sync."
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="1"
                        CornerRadius="24"
                        Padding="24"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        Background="{Binding PresenterDisplay.DisplayBackgroundBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock FontFamily="{Binding PresenterDisplay.TitleFontFamily}"
                                       FontSize="{Binding PresenterDisplay.TitleFontSize}"
                                       FontWeight="Bold"
                                       Foreground="{Binding PresenterDisplay.ForegroundBrush}"
                                       Text="{Binding LiveDeckTitle}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{Binding PresenterDisplay.AccentBrush}"
                                       Text="{Binding LiveDeckSubtitle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Foreground="{Binding PresenterDisplay.AccentBrush}"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Text="{Binding CurrentSlideHeading}" />
                                <TextBlock Margin="0,24,0,0"
                                           FontFamily="{Binding PresenterDisplay.BodyFontFamily}"
                                           FontSize="{Binding PresenterDisplay.BodyFontSize}"
                                           Foreground="{Binding PresenterDisplay.ForegroundBrush}"
                                           Text="{Binding CurrentSlideText}"
                                           TextAlignment="{Binding PresenterDisplay.DisplayTextAlignment}"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Foreground="{StaticResource AppMutedInkBrush}" Text="{Binding StorageSummary}" TextWrapping="Wrap" />
                    <TextBlock Grid.Column="1"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppHighlightBrush}"
                               Text="{Binding CurrentPresentationSummary}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
