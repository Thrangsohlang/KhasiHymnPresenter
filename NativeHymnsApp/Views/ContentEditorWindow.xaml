<Window x:Class="NativeHymnsApp.Views.ContentEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Content Editor"
        Width="760"
        Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="InstructionsText" TextWrapping="Wrap" Foreground="#D3C9B3" />

        <StackPanel Grid.Row="1" Margin="0,16,0,12">
            <TextBlock Text="Title" />
            <TextBox x:Name="TitleTextBox" />
        </StackPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Content" />
            <TextBox x:Name="ContentTextBox"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap"
                     MinHeight="420" />
        </StackPanel>

        <WrapPanel Grid.Row="3" Margin="0,14,0,0" HorizontalAlignment="Right">
            <Button Click="Save_Click" Content="Save" />
            <Button Click="Cancel_Click" Content="Cancel" />
        </WrapPanel>
    </Grid>
</Window>
