<Window x:Class="NativeHymnsApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:NativeHymnsApp.Models"
        mc:Ignorable="d"
        Title="Khasi Hymns Presenter"
        Width="1460"
        Height="920"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        WindowState="Maximized"
        Loaded="MainWindow_OnLoaded"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding ShowSlideshowCommand}" />
        <KeyBinding Key="PageDown" Command="{Binding NextSlideCommand}" />
        <KeyBinding Key="PageUp" Command="{Binding PreviousSlideCommand}" />
        <KeyBinding Key="Right" Command="{Binding NextSlideCommand}" />
        <KeyBinding Key="Left" Command="{Binding PreviousSlideCommand}" />
        <KeyBinding Key="B" Command="{Binding BlackScreenCommand}" />
        <KeyBinding Key="W" Command="{Binding BlankScreenCommand}" />
        <KeyBinding Key="Escape" Command="{Binding ClearOverlayCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="ShellCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="HeroTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Georgia" />
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource AppInkBrush}" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppMutedInkBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="NumberLookupTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Width" Value="132" />
            <Setter Property="MaxLength" Value="4" />
        </Style>

        <Style x:Key="CustomSongIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:SongKind.CustomSong}">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Background="{StaticResource AppCanvasBrush}">
        <Border DockPanel.Dock="Top"
                Margin="0,0,0,1"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,0,0,1">
            <Menu>
                <MenuItem Header="_File">
                    <MenuItem Header="_Reload Data" Command="{Binding ReloadCatalogCommand}" />
                    <Separator />
                    <MenuItem Header="E_xit" Click="ExitMenuItem_Click" />
                </MenuItem>
                <MenuItem Header="_Library">
                    <MenuItem Header="_Add Custom Song" Click="AddCustomSong_Click" />
                    <MenuItem Header="_Edit Selected Custom Song" Click="EditCustomSong_Click" IsEnabled="{Binding CanEditSelectedCustomSong}" />
                    <MenuItem Header="_Delete Selected Custom Song" Click="DeleteCustomSong_Click" IsEnabled="{Binding CanEditSelectedCustomSong}" />
                </MenuItem>
                <MenuItem Header="_Slideshow">
                    <MenuItem Header="_Open Slideshow" Command="{Binding ShowSlideshowCommand}" />
                    <MenuItem Header="_Previous Slide" Command="{Binding PreviousSlideCommand}" />
                    <MenuItem Header="_Next Slide" Command="{Binding NextSlideCommand}" />
                    <Separator />
                    <MenuItem Header="_Blank Screen" Command="{Binding BlankScreenCommand}" />
                    <MenuItem Header="_Black Screen" Command="{Binding BlackScreenCommand}" />
                    <MenuItem Header="_Clear Overlay" Command="{Binding ClearOverlayCommand}" />
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem Header="_Theme Editor" Click="OpenThemeEditor_Click" />
                </MenuItem>
            </Menu>
        </Border>

        <Border DockPanel.Dock="Top"
                Margin="16,16,16,12"
                Padding="22"
                CornerRadius="22"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource HeroTitleStyle}" Text="Khasi Hymns Presenter" />
                    <TextBlock Margin="0,6,0,0" Style="{StaticResource MutedTextStyle}" Text="{Binding DataSourceSummary}" />
                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource AppHighlightBrush}" Text="{Binding CurrentPresentationSummary}" TextWrapping="Wrap" />
                </StackPanel>

                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Command="{Binding ShowSlideshowCommand}" Content="Open Slideshow" />
                    <Button Click="OpenThemeEditor_Click" Content="Theme Editor" />
                    <Button Command="{Binding ReloadCatalogCommand}" Content="Reload" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Margin="16,0,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ShellCardStyle}" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Service Plan" />
                        <TextBlock Margin="0,4,0,0" Style="{StaticResource MutedTextStyle}" Text="{Binding ServicePlanSummary}" />
                    </StackPanel>

                    <WrapPanel Grid.Row="1" Margin="0,16,0,8">
                        <Button Click="AddTextSlide_Click" Content="Add Program Slide" />
                        <Button Command="{Binding PresentSelectedPlanEntryCommand}" Content="Load Selected" />
                        <Button Command="{Binding MovePlanItemUpCommand}" Content="Move Up" />
                        <Button Command="{Binding MovePlanItemDownCommand}" Content="Move Down" />
                        <Button Command="{Binding ClearPlanCommand}" Content="Clear" />
                    </WrapPanel>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding ServicePlanItems}"
                             SelectedItem="{Binding SelectedServicePlanEntry}"
                             BorderThickness="0"
                             Background="Transparent"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ServicePlanEntry}">
                                <Border x:Name="PlanRow"
                                        Margin="0,0,0,8"
                                        Padding="12"
                                        CornerRadius="12"
                                        Background="{StaticResource AppSurfaceAltBrush}"
                                        BorderBrush="{StaticResource AppBorderBrush}"
                                        BorderThickness="1">
                                    <DockPanel LastChildFill="True">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Style="{StaticResource IconButtonStyle}"
                                                    ToolTip="Load to slideshow"
                                                    Command="{Binding DataContext.PresentServicePlanItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Content="&#xE768;" />
                                            <Button Style="{StaticResource IconButtonStyle}"
                                                    ToolTip="Remove from plan"
                                                    Command="{Binding DataContext.RemoveServicePlanItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Content="&#xE74D;" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,10,0">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding DisplayTitle}" TextWrapping="Wrap" />
                                            <TextBlock Margin="0,4,0,0" Foreground="{StaticResource AppMutedInkBrush}" Text="{Binding KindLabel}" />
                                            <TextBlock Margin="0,2,0,0" Foreground="{StaticResource AppMutedInkBrush}" Text="{Binding SlideCountLabel}" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="PlanRow" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                                        <Setter TargetName="PlanRow" Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="12"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ShowsPreview="True" />

            <Grid Grid.Column="2" Margin="0,0,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="260" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ShellCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Quick Hymn Number" />
                            <TextBox Style="{StaticResource NumberLookupTextBoxStyle}"
                                     Text="{Binding HymnNumberLookupText, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SelectHymnByNumberCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Search Library" />
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,4,0,0" Style="{StaticResource MutedTextStyle}" Text="{Binding QuickSelectSubtitle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="12,0,0,0">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Filter" />
                            <ComboBox ItemsSource="{Binding LibraryFilters}" SelectedItem="{Binding SelectedLibraryFilter}" />
                            <CheckBox Content="Fuzzy matching" IsChecked="{Binding IsFuzzySearchEnabled}" />
                        </StackPanel>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Top">
                            <Button Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Select hymn number"
                                    Command="{Binding SelectHymnByNumberCommand}"
                                    Content="&#xE8A1;" />
                            <Button Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Add custom song"
                                    Click="AddCustomSong_Click"
                                    Content="&#xE710;" />
                            <Button Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Reload catalog"
                                    Command="{Binding ReloadCatalogCommand}"
                                    Content="&#xE72C;" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource ShellCardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="18,18,18,10">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Matching Hymns" />
                                <TextBlock Margin="0,4,0,0" Style="{StaticResource MutedTextStyle}" Text="{Binding LibrarySummary}" />
                            </StackPanel>

                            <TextBlock DockPanel.Dock="Right"
                                       VerticalAlignment="Bottom"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AppHighlightBrush}"
                                       Text="{Binding QuickSelectTitle}" />
                        </DockPanel>

                        <ListBox Grid.Row="1"
                                 Margin="10,0,10,10"
                                 ItemsSource="{Binding LibraryItems}"
                                 SelectedItem="{Binding SelectedLibrarySong}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:SongDocument}">
                                    <Border x:Name="LibraryRow"
                                            Margin="0,0,0,6"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="{StaticResource AppSurfaceAltBrush}"
                                            BorderBrush="{StaticResource AppBorderBrush}"
                                            BorderThickness="1">
                                        <DockPanel LastChildFill="True">
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Style="{StaticResource IconButtonStyle}"
                                                        ToolTip="Queue in service plan"
                                                        Command="{Binding DataContext.QueueLibrarySongCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Content="&#xE710;" />
                                                <Button Style="{StaticResource IconButtonStyle}"
                                                        ToolTip="Load to slideshow"
                                                        Command="{Binding DataContext.PresentLibrarySongCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Content="&#xE768;" />
                                                <Button Style="{StaticResource CustomSongIconButtonStyle}"
                                                        ToolTip="Edit custom song"
                                                        Tag="{Binding}"
                                                        Click="EditLibrarySong_Click"
                                                        Content="&#xE70F;" />
                                                <Button Style="{StaticResource CustomSongIconButtonStyle}"
                                                        ToolTip="Delete custom song"
                                                        Tag="{Binding}"
                                                        Click="DeleteLibrarySong_Click"
                                                        Content="&#xE74D;" />
                                            </StackPanel>

                                            <Grid Margin="0,0,12,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="72" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="58"
                                                        Height="58"
                                                        VerticalAlignment="Center"
                                                        CornerRadius="16"
                                                        Background="{StaticResource AppSurfaceBrush}"
                                                        BorderBrush="{StaticResource AppBorderBrush}"
                                                        BorderThickness="1">
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock HorizontalAlignment="Center"
                                                                   FontSize="22"
                                                                   FontWeight="Bold"
                                                                   Text="{Binding HymnNumber, TargetNullValue=C}" />
                                                        <TextBlock HorizontalAlignment="Center"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource AppMutedInkBrush}"
                                                                   Text="{Binding KindLabel}" />
                                                    </StackPanel>
                                                </Border>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock FontSize="17"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding Title}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Foreground="{StaticResource AppMutedInkBrush}"
                                                               Text="{Binding DisplaySubtitle}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Margin="0,2,0,0"
                                                               Foreground="{StaticResource AppMutedInkBrush}"
                                                               Text="{Binding SlideCountLabel}" />
                                                </StackPanel>
                                            </Grid>
                                        </DockPanel>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                            <Setter TargetName="LibraryRow" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                                            <Setter TargetName="LibraryRow" Property="Background" Value="{StaticResource AppAccentSoftBrush}" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="3"
                              Height="12"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Background="Transparent"
                              ShowsPreview="True" />

                <Border Grid.Row="4" Style="{StaticResource ShellCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,12">
                            <StackPanel DockPanel.Dock="Left" MaxWidth="560">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding PreviewTitle}" />
                                <TextBlock Margin="0,4,0,0" Style="{StaticResource MutedTextStyle}" Text="{Binding PreviewSubtitle}" />
                            </StackPanel>
                            <WrapPanel DockPanel.Dock="Right">
                                <Button Command="{Binding AddSelectedToPlanCommand}" Content="Queue Selection" />
                                <Button Command="{Binding PresentSelectedSongCommand}" Content="Load Selection" />
                            </WrapPanel>
                        </DockPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding PreviewSlides}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:SlideSection}">
                                        <Border Margin="0,0,0,10"
                                                Padding="12"
                                                CornerRadius="12"
                                                Background="{StaticResource AppSurfaceAltBrush}"
                                                BorderBrush="{StaticResource AppBorderBrush}"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SectionLabelStyle}" Text="{Binding Heading}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding Text}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border DockPanel.Dock="Bottom"
                Margin="16,0,16,16"
                Padding="14,10"
                CornerRadius="18"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Style="{StaticResource MutedTextStyle}" Text="{Binding StorageSummary}" />
                <TextBlock Grid.Column="1" Foreground="{StaticResource AppAccentBrush}" Text="Planning workspace | live slideshow window | projector output" />
            </Grid>
        </Border>
    </DockPanel>
</Window>
